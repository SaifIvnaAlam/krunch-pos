{
  "name": "universal-pos",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/check-node.mjs && npm run db:up && node scripts/wait-for-postgres.mjs && turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "generate:openapi": "turbo run generate:openapi --filter=@universal-pos/api",
    "db:up": "docker compose up -d postgres adminer",
    "db:down": "docker compose down",
    "db:setup": "npm run db:up && npm run db:push",
    "db:push": "sh -c 'set -a && . ./apps/api/.env && set +a && turbo run db:push --filter=@universal-pos/database-schema'",
    "db:migrate": "sh -c 'set -a && . ./apps/api/.env && set +a && turbo run db:migrate --filter=@universal-pos/database-schema'",
    "db:seed": "sh -c 'set -a && . ./apps/api/.env && set +a && turbo run db:seed --filter=@universal-pos/database-schema'",
    "db:generate": "turbo run db:generate --filter=@universal-pos/database-schema",
    "deploy:vps": "bash scripts/deploy-to-vps.sh"
  },
  "devDependencies": {
    "prettier": "^3.x",
    "turbo": "^2.x",
    "typescript": "^5.x"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.0.0"
}
