# ── Database (Supabase PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-64-byte-random-hex
JWT_REFRESH_SECRET=change-me-to-a-different-64-byte-random-hex
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=28800
OVERRIDE_TOKEN_EXPIRY=60

# ── Security ──────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
PBKDF2_ITERATIONS=100000

# ── Object storage (MinIO / S3-compatible) ───────────────
S3_ENDPOINT=http://217.154.53.60:9000
S3_REGION=us-east-1
S3_BUCKET=krunch-pos
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRY_SECONDS=900

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Terminal (Vite: apps/terminal/.env — see apps/terminal/.env.example) ──
# VITE_API_URL, VITE_USE_DEMO_DATA=true for UI-only mock, VITE_SEEDED_ADMIN_EMAIL, branch/terminal ids

# ── Terminal Clients (local config) ───────────────────────
BRANCH_ID=
TERMINAL_ID=
API_BASE_URL=http://localhost:3000
SYNC_GATEWAY_URL=ws://localhost:3000
SQLITE_PATH=./data/branch.db
TOKEN_ENCRYPTION_KEY=change-me-aes-256-key
