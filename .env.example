# ── Database (Supabase PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-64-byte-random-hex
JWT_REFRESH_SECRET=change-me-to-a-different-64-byte-random-hex
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=28800
OVERRIDE_TOKEN_EXPIRY=60

# ── Security ──────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
PBKDF2_ITERATIONS=100000

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Terminal Clients (local config) ───────────────────────
BRANCH_ID=
TERMINAL_ID=
API_BASE_URL=http://localhost:3000
SYNC_GATEWAY_URL=ws://localhost:3000
SQLITE_PATH=./data/branch.db
TOKEN_ENCRYPTION_KEY=change-me-aes-256-key
