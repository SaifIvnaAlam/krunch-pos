<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TerminalWin.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TerminalWin.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="PinDigitButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Page.Resources>

    <Grid>
        <!-- ══════════════════════════════════════════
             MAIN TWO-COLUMN LAYOUT
             ══════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── LEFT SIDEBAR ── -->
            <Grid Grid.Column="0" Background="#1E293B" Padding="28,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Branding -->
                <StackPanel Grid.Row="0" Spacing="6">
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="#2563EB" HorizontalAlignment="Left"
                            Margin="0,0,0,14">
                        <TextBlock Text="U" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="White">
                        <Run Text="Universal" />
                        <Run Text=" POS" Foreground="#60A5FA" />
                    </TextBlock>
                    <TextBlock Text="Restaurant Terminal"
                               FontSize="12" Foreground="#94A3B8"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Bottom section: status, date/time, version -->
                <StackPanel Grid.Row="2" Spacing="16">
                    <!-- Online indicator -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                Visibility="{x:Bind ViewModel.IsOnline, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#10B981" VerticalAlignment="Center" />
                        <TextBlock Text="Online" FontSize="13" Foreground="#94A3B8" />
                    </StackPanel>

                    <!-- Offline indicator -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                Visibility="{x:Bind ViewModel.IsOnline, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#EF4444" VerticalAlignment="Center" />
                        <TextBlock Text="Offline" FontSize="13" Foreground="#EF4444"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <Border Height="1" Background="#334155" />

                    <!-- Date and time -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.CurrentDate, Mode=OneWay}"
                                   FontSize="12" Foreground="#94A3B8" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentTime, Mode=OneWay}"
                                   FontSize="40" FontWeight="Bold" Foreground="White" />
                    </StackPanel>

                    <TextBlock Text="v0.1.0" FontSize="11" Foreground="#475569" />
                </StackPanel>
            </Grid>

            <!-- ── MAIN CONTENT AREA ── -->
            <Grid Grid.Column="1" Background="#F8FAFC">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Padding="40,36,40,0" Spacing="4">
                    <TextBlock Text="Select Staff"
                               FontSize="28" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock Text="Choose your profile to begin"
                               FontSize="15" Foreground="#64748B" />
                </StackPanel>

                <!-- Staff grid -->
                <GridView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.CachedStaff}"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="StaffGrid_ItemClick"
                          Padding="32,24"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollMode="Disabled">

                    <GridView.Footer>
                        <Button Command="{x:Bind ViewModel.ShowOtherStaffCommand}"
                                Background="Transparent"
                                BorderBrush="#94A3B8"
                                BorderThickness="1.5"
                                CornerRadius="12"
                                Width="176" MinHeight="196"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Margin="8">
                            <StackPanel HorizontalAlignment="Center" Spacing="12">
                                <Border Width="56" Height="56" CornerRadius="28"
                                        Background="#F1F5F9" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE710;" FontSize="22"
                                              Foreground="#64748B" />
                                </Border>
                                <TextBlock Text="Other Staff"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#64748B"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </GridView.Footer>

                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="CornerRadius" Value="12" />
                            <Setter Property="MinWidth" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </GridView.ItemContainerStyle>

                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:StaffQuickSelect">
                            <Border Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Width="176" MinHeight="196" Padding="16,24">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center" Spacing="12">
                                    <!-- Avatar circle -->
                                    <Border Width="56" Height="56" CornerRadius="28"
                                            Background="{x:Bind AvatarColor, Converter={StaticResource HexColorToBrushConverter}}"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind Initials}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="White" />
                                    </Border>
                                    <!-- Name -->
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1E293B"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="140" />
                                    <!-- Role badge -->
                                    <Border Background="#E0F2FE" CornerRadius="10"
                                            Padding="10,4" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind Role}"
                                                   FontSize="11" Foreground="#0369A1"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════
             PIN PAD OVERLAY
             ══════════════════════════════════════════ -->
        <Grid Visibility="{x:Bind ViewModel.IsPinPadVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <!-- Semi-transparent dark backdrop -->
            <Border Background="#99000000" />

            <!-- Modal card -->
            <Border Background="White" CornerRadius="20"
                    Width="400" Padding="36,32"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#E2E8F0" BorderThickness="1"
                    Translation="0,0,48">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>

                <StackPanel Spacing="20" Width="328">
                    <!-- Selected staff name (known staff mode) -->
                    <TextBlock Text="{x:Bind ViewModel.SelectedStaffName, Mode=OneWay}"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#0F172A"
                               Visibility="{x:Bind ViewModel.IsOtherStaffMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}" />

                    <!-- Staff ID input (other staff mode) -->
                    <StackPanel Spacing="10"
                                Visibility="{x:Bind ViewModel.IsOtherStaffMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Enter Staff ID"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#0F172A" />
                        <TextBox Text="{x:Bind ViewModel.StaffId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="e.g. staff-001"
                                 FontSize="15" Padding="14" CornerRadius="10" />
                    </StackPanel>

                    <!-- Subtitle -->
                    <TextBlock Text="Enter your PIN"
                               FontSize="14" Foreground="#64748B"
                               HorizontalAlignment="Center" />

                    <!-- PIN dot display -->
                    <Border Background="#F1F5F9" CornerRadius="12"
                            Padding="24,14" HorizontalAlignment="Center"
                            MinWidth="220">
                        <TextBlock Text="{x:Bind ViewModel.PinDisplay, Mode=OneWay}"
                                   FontSize="34" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   CharacterSpacing="500" MinHeight="40"
                                   Foreground="#0F172A" />
                    </Border>

                    <!-- 3x4 numeric grid -->
                    <Grid ColumnSpacing="10" RowSpacing="10" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="84" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64" />
                            <RowDefinition Height="64" />
                            <RowDefinition Height="64" />
                            <RowDefinition Height="64" />
                        </Grid.RowDefinitions>

                        <Button Content="1" Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="1" />
                        <Button Content="2" Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="2" />
                        <Button Content="3" Grid.Row="0" Grid.Column="2"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="3" />

                        <Button Content="4" Grid.Row="1" Grid.Column="0"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="4" />
                        <Button Content="5" Grid.Row="1" Grid.Column="1"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="5" />
                        <Button Content="6" Grid.Row="1" Grid.Column="2"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="6" />

                        <Button Content="7" Grid.Row="2" Grid.Column="0"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="7" />
                        <Button Content="8" Grid.Row="2" Grid.Column="1"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="8" />
                        <Button Content="9" Grid.Row="2" Grid.Column="2"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="9" />

                        <!-- Backspace -->
                        <Button Grid.Row="3" Grid.Column="0"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.BackspaceCommand}">
                            <TextBlock Text="&#x232B;" FontSize="22" />
                        </Button>
                        <Button Content="0" Grid.Row="3" Grid.Column="1"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Command="{x:Bind ViewModel.AppendDigitCommand}" CommandParameter="0" />
                        <!-- Clear -->
                        <Button Content="C" Grid.Row="3" Grid.Column="2"
                                Style="{StaticResource PinDigitButtonStyle}"
                                Foreground="#DC2626"
                                Command="{x:Bind ViewModel.ClearPinCommand}" />
                    </Grid>

                    <!-- Error message -->
                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               Foreground="#DC2626" FontSize="13"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" />

                    <!-- Login button -->
                    <Button Content="Log In"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            FontSize="16" FontWeight="SemiBold"
                            Padding="16,14" CornerRadius="12"
                            Command="{x:Bind ViewModel.LoginCommand}"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />

                    <!-- Loading spinner -->
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  HorizontalAlignment="Center"
                                  Width="28" Height="28" />

                    <!-- Cancel link -->
                    <HyperlinkButton Content="Cancel"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     Command="{x:Bind ViewModel.ClosePinPadCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
