<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TerminalWin.Views.PaymentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TerminalWin.ViewModels"
    Background="#F1F5F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════ TOP BAR ═══════════════ -->
        <Grid Grid.Row="0" Background="#0F172A" Padding="8,0,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Command="{x:Bind ViewModel.GoBackCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="White" />
                </Button>
                <TextBlock Text="Payment" FontSize="16" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Total:" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.GrandTotalDisplay, Mode=OneWay}"
                           Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ═══════════════ CONTENT ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!-- ─────── LEFT: ORDER SUMMARY ─────── -->
            <Grid Grid.Column="0" Background="#F8FAFC" Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Order Summary" FontSize="20" FontWeight="Bold"
                           Foreground="#0F172A" Margin="0,0,0,16" />

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.OrderItems}"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:OrderItemDisplay">
                            <Grid Padding="12,10" ColumnSpacing="12"
                                  BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#EFF6FF" CornerRadius="6"
                                        Width="32" Height="28" HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#0369A1">
                                        <Run Text="{x:Bind Quantity}" /><Run Text="x" />
                                    </TextBlock>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="14"
                                           Foreground="#1E293B" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{x:Bind TotalDisplay}" FontSize="14"
                                           FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Totals -->
                <StackPanel Grid.Row="2" Spacing="8" Padding="0,16,0,0"
                            BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <Grid>
                        <TextBlock Text="Subtotal" FontSize="14" Foreground="#64748B" />
                        <TextBlock Text="{x:Bind ViewModel.SubtotalDisplay, Mode=OneWay}"
                                   FontSize="14" Foreground="#64748B" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Tax (10%)" FontSize="14" Foreground="#64748B" />
                        <TextBlock Text="{x:Bind ViewModel.TaxDisplay, Mode=OneWay}"
                                   FontSize="14" Foreground="#64748B" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Tip" FontSize="14" Foreground="#64748B" />
                        <TextBlock Text="{x:Bind ViewModel.TipDisplay, Mode=OneWay}"
                                   FontSize="14" Foreground="#64748B" HorizontalAlignment="Right" />
                    </Grid>
                    <Rectangle Height="1" Fill="#CBD5E1" Margin="0,4" />
                    <Grid>
                        <TextBlock Text="Grand Total" FontSize="18" FontWeight="Bold" Foreground="#0F172A" />
                        <TextBlock Text="{x:Bind ViewModel.GrandTotalDisplay, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" Foreground="#0369A1"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- ─────── RIGHT: PAYMENT CONTROLS ─────── -->
            <Border Grid.Column="1" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                    <StackPanel Spacing="24">

                        <!-- Grand Total Display -->
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Amount Due" FontSize="13" Foreground="#64748B"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.GrandTotalDisplay, Mode=OneWay}"
                                       FontSize="36" FontWeight="Bold" Foreground="#0F172A"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- ── Tip Section ── -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Add Tip" FontSize="14" FontWeight="SemiBold" Foreground="#334155" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="No Tip" FontSize="12"
                                        HorizontalAlignment="Stretch" Padding="4,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.SelectTipCommand}" CommandParameter="None"
                                        Background="{x:Bind ViewModel.IsTipNone, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#F1F5F9'}"
                                        Foreground="{x:Bind ViewModel.IsTipNone, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#334155'}" />
                                <Button Grid.Column="1" Content="10%" FontSize="12"
                                        HorizontalAlignment="Stretch" Padding="4,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.SelectTipCommand}" CommandParameter="10%"
                                        Background="{x:Bind ViewModel.IsTip10, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#F1F5F9'}"
                                        Foreground="{x:Bind ViewModel.IsTip10, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#334155'}" />
                                <Button Grid.Column="2" Content="15%" FontSize="12"
                                        HorizontalAlignment="Stretch" Padding="4,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.SelectTipCommand}" CommandParameter="15%"
                                        Background="{x:Bind ViewModel.IsTip15, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#F1F5F9'}"
                                        Foreground="{x:Bind ViewModel.IsTip15, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#334155'}" />
                                <Button Grid.Column="3" Content="20%" FontSize="12"
                                        HorizontalAlignment="Stretch" Padding="4,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.SelectTipCommand}" CommandParameter="20%"
                                        Background="{x:Bind ViewModel.IsTip20, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#F1F5F9'}"
                                        Foreground="{x:Bind ViewModel.IsTip20, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#334155'}" />
                                <Button Grid.Column="4" Content="Custom" FontSize="12"
                                        HorizontalAlignment="Stretch" Padding="4,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.SelectTipCommand}" CommandParameter="Custom"
                                        Background="{x:Bind ViewModel.IsTipCustom, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#F1F5F9'}"
                                        Foreground="{x:Bind ViewModel.IsTipCustom, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#334155'}" />
                            </Grid>

                            <TextBox PlaceholderText="Enter tip amount"
                                     Text="{x:Bind ViewModel.CustomTipText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{x:Bind ViewModel.IsTipCustom, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                     FontSize="14" CornerRadius="8" Padding="12,10"
                                     InputScope="CurrencyAmount" />
                        </StackPanel>

                        <Rectangle Height="1" Fill="#E2E8F0" />

                        <!-- ── Payment Method ── -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Payment Method" FontSize="14" FontWeight="SemiBold" Foreground="#334155" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                        Padding="12,12" CornerRadius="10"
                                        Command="{x:Bind ViewModel.SelectPaymentMethodCommand}" CommandParameter="Cash"
                                        Background="{x:Bind ViewModel.IsCashMethod, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#F1F5F9'}"
                                        Foreground="{x:Bind ViewModel.IsCashMethod, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#334155'}"
                                        BorderThickness="0">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE7BF;" FontSize="16" />
                                        <TextBlock Text="Cash" FontSize="14" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" HorizontalAlignment="Stretch"
                                        Padding="12,12" CornerRadius="10"
                                        Command="{x:Bind ViewModel.SelectPaymentMethodCommand}" CommandParameter="Card"
                                        Background="{x:Bind ViewModel.IsCardMethod, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#F1F5F9'}"
                                        Foreground="{x:Bind ViewModel.IsCardMethod, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#334155'}"
                                        BorderThickness="0">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8C7;" FontSize="16" />
                                        <TextBlock Text="Card" FontSize="14" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- ── Cash Section ── -->
                        <StackPanel Spacing="12"
                                    Visibility="{x:Bind ViewModel.IsCashMethod, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBox Header="Cash Tendered" PlaceholderText="0.00"
                                     Text="{x:Bind ViewModel.CashTenderedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="18" CornerRadius="8" Padding="12,10"
                                     InputScope="CurrencyAmount" />

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="$20" FontSize="14"
                                        HorizontalAlignment="Stretch" Padding="8,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.QuickCashCommand}" CommandParameter="20"
                                        Background="#F1F5F9" BorderThickness="0" />
                                <Button Grid.Column="1" Content="$50" FontSize="14"
                                        HorizontalAlignment="Stretch" Padding="8,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.QuickCashCommand}" CommandParameter="50"
                                        Background="#F1F5F9" BorderThickness="0" />
                                <Button Grid.Column="2" Content="$100" FontSize="14"
                                        HorizontalAlignment="Stretch" Padding="8,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.QuickCashCommand}" CommandParameter="100"
                                        Background="#F1F5F9" BorderThickness="0" />
                                <Button Grid.Column="3" Content="Exact" FontSize="14"
                                        HorizontalAlignment="Stretch" Padding="8,10" CornerRadius="8"
                                        Command="{x:Bind ViewModel.QuickCashCommand}" CommandParameter="Exact"
                                        Background="#F1F5F9" BorderThickness="0" />
                            </Grid>

                            <Border Background="#F0FDF4" CornerRadius="10" Padding="16,12">
                                <Grid>
                                    <TextBlock Text="Change" FontSize="14" Foreground="#166534"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.ChangeOwedDisplay, Mode=OneWay}"
                                               FontSize="22" FontWeight="Bold" Foreground="#16A34A"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ── Card Section ── -->
                        <StackPanel Spacing="16" Padding="0,16"
                                    HorizontalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.IsCardMethod, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ProgressRing IsActive="True" Width="48" Height="48" />
                            <TextBlock Text="Tap, insert, or swipe card"
                                       FontSize="14" Foreground="#64748B"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Waiting for card reader..."
                                       FontSize="12" Foreground="#94A3B8"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <Rectangle Height="1" Fill="#E2E8F0" />

                        <!-- ── Action Buttons ── -->
                        <StackPanel Spacing="10">
                            <Button Command="{x:Bind ViewModel.ProcessPaymentCommand}"
                                    HorizontalAlignment="Stretch"
                                    Padding="16,16" CornerRadius="12"
                                    Background="#16A34A" Foreground="White" BorderThickness="0"
                                    IsEnabled="{x:Bind ViewModel.CanProcessPayment, Mode=OneWay}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15803D" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#166534" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                </Button.Resources>
                                <TextBlock Text="Complete Payment" FontSize="16" FontWeight="Bold" />
                            </Button>

                            <Button Content="Cancel" Command="{x:Bind ViewModel.GoBackCommand}"
                                    HorizontalAlignment="Stretch"
                                    FontSize="14" Padding="12,10" CornerRadius="8"
                                    Background="Transparent" BorderBrush="#CBD5E1" BorderThickness="1"
                                    Foreground="#64748B" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════ PROCESSING OVERLAY ═══════════════ -->
        <Grid Grid.RowSpan="2"
              Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#CC0F172A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <ProgressRing IsActive="True" Width="56" Height="56" Foreground="White" />
                <TextBlock Text="Processing payment..." Foreground="White"
                           FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ═══════════════ COMPLETE OVERLAY ═══════════════ -->
        <Grid Grid.RowSpan="2"
              Visibility="{x:Bind ViewModel.IsPaymentComplete, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#CC0F172A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE73E;" FontSize="56" Foreground="#22C55E" />
                <TextBlock Text="Payment Complete!" Foreground="White"
                           FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
