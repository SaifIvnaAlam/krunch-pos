<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TerminalWin.Views.TableSelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TerminalWin.ViewModels"
    xmlns:converters="using:TerminalWin.Converters"
    Background="#F3F4F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════ Top Bar ═══════ -->
        <Grid Grid.Row="0" Background="#0F172A" Padding="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="12">
                <Grid Width="36" Height="36" CornerRadius="18">
                    <Border Background="#334155" CornerRadius="18" />
                    <TextBlock Text="{x:Bind ViewModel.StaffInitial, Mode=OneWay}"
                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <TextBlock Text="{x:Bind ViewModel.StaffName, Mode=OneWay}"
                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Grid.Column="1" Text="Universal POS"
                       FontSize="20" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />

            <Button Grid.Column="2" Content="Log Out"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Foreground="#FCA5A5" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="0"
                    Command="{x:Bind ViewModel.LogoutCommand}"
                    CornerRadius="6" Padding="16,8" FontSize="13" />
        </Grid>

        <!-- ═══════ Order Type Tabs ═══════ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8" Padding="24,12">

                <Button Content="Dine In" Height="40" CornerRadius="20"
                        Padding="28,0" FontSize="14" FontWeight="SemiBold"
                        BorderThickness="1.5"
                        Background="{x:Bind ViewModel.IsDineIn, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#FFFFFF'}"
                        Foreground="{x:Bind ViewModel.IsDineIn, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#6B7280'}"
                        BorderBrush="{x:Bind ViewModel.IsDineIn, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#E5E7EB'}"
                        Command="{x:Bind ViewModel.SelectOrderTypeCommand}"
                        CommandParameter="DineIn" />

                <Button Content="Takeaway" Height="40" CornerRadius="20"
                        Padding="28,0" FontSize="14" FontWeight="SemiBold"
                        BorderThickness="1.5"
                        Background="{x:Bind ViewModel.IsTakeaway, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#FFFFFF'}"
                        Foreground="{x:Bind ViewModel.IsTakeaway, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#6B7280'}"
                        BorderBrush="{x:Bind ViewModel.IsTakeaway, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#E5E7EB'}"
                        Command="{x:Bind ViewModel.SelectOrderTypeCommand}"
                        CommandParameter="Takeaway" />

                <Button Content="Delivery" Height="40" CornerRadius="20"
                        Padding="28,0" FontSize="14" FontWeight="SemiBold"
                        BorderThickness="1.5"
                        Background="{x:Bind ViewModel.IsDelivery, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#FFFFFF'}"
                        Foreground="{x:Bind ViewModel.IsDelivery, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FFFFFF|#6B7280'}"
                        BorderBrush="{x:Bind ViewModel.IsDelivery, Mode=OneWay, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#0369A1|#E5E7EB'}"
                        Command="{x:Bind ViewModel.SelectOrderTypeCommand}"
                        CommandParameter="Delivery" />

            </StackPanel>
        </Border>

        <!-- ═══════ Content Area ═══════ -->
        <Grid Grid.Row="2">

            <!-- ─── Table Grid (Dine In) ─── -->
            <ScrollViewer Visibility="{x:Bind ViewModel.IsDineIn, Mode=OneWay}"
                          Padding="24,20,24,24">
                <StackPanel Spacing="16">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Select a Table"
                                       FontSize="22" FontWeight="Bold" Foreground="#111827" />
                            <TextBlock Text="20 tables available"
                                       FontSize="13" Foreground="#6B7280" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="16"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="#DCFCE7" BorderBrush="#22C55E" BorderThickness="1.5" />
                                <TextBlock Text="Available" FontSize="12" Foreground="#6B7280"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="#DBEAFE" BorderBrush="#3B82F6" BorderThickness="1.5" />
                                <TextBlock Text="Occupied" FontSize="12" Foreground="#6B7280"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1.5" />
                                <TextBlock Text="Reserved" FontSize="12" Foreground="#6B7280"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <GridView ItemsSource="{x:Bind ViewModel.Tables}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="TableGrid_ItemClick">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="6" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TableInfo">
                                <Grid Width="148" Height="116" CornerRadius="12" Padding="12"
                                      Background="{x:Bind BackgroundColor, Converter={StaticResource HexColorToBrushConverter}}"
                                      BorderBrush="{x:Bind BorderColor, Converter={StaticResource HexColorToBrushConverter}}"
                                      BorderThickness="2">

                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind DisplayNumber}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="#1E293B"
                                                   HorizontalAlignment="Center" />

                                        <TextBlock Text="{x:Bind DisplaySeats}"
                                                   FontSize="12" Foreground="#64748B"
                                                   HorizontalAlignment="Center" />

                                        <TextBlock Text="{x:Bind OrderTotal}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#2563EB"
                                                   HorizontalAlignment="Center"
                                                   Visibility="{x:Bind OrderTotal, Converter={StaticResource StringToVisibilityConverter}}" />

                                        <Border Background="#FDE68A" CornerRadius="4"
                                                Padding="8,2" HorizontalAlignment="Center"
                                                Visibility="{x:Bind IsReserved}">
                                            <TextBlock Text="Reserved" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#92400E" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </ScrollViewer>

            <!-- ─── Takeaway Panel ─── -->
            <Grid Visibility="{x:Bind ViewModel.IsTakeaway, Mode=OneWay}"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Width="400" Padding="40" Spacing="24"
                            Background="White" CornerRadius="16"
                            BorderBrush="#E5E7EB" BorderThickness="1"
                            HorizontalAlignment="Center">

                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="New Takeaway Order"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#111827"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Start a new order for pickup"
                                   FontSize="14" Foreground="#6B7280"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <Button Content="Start Order"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            FontSize="16" FontWeight="SemiBold"
                            Padding="16,16" CornerRadius="10"
                            Command="{x:Bind ViewModel.StartNewOrderCommand}" />
                </StackPanel>
            </Grid>

            <!-- ─── Delivery Panel ─── -->
            <Grid Visibility="{x:Bind ViewModel.IsDelivery, Mode=OneWay}"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Width="400" Padding="40" Spacing="20"
                            Background="White" CornerRadius="16"
                            BorderBrush="#E5E7EB" BorderThickness="1"
                            HorizontalAlignment="Center">

                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="New Delivery Order"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#111827"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Enter customer delivery details"
                                   FontSize="14" Foreground="#6B7280"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Customer Name" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#374151" />
                        <TextBox PlaceholderText="Enter customer name"
                                 Text="{x:Bind ViewModel.CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15" Padding="12" CornerRadius="8" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Phone Number" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#374151" />
                        <TextBox PlaceholderText="Enter phone number"
                                 Text="{x:Bind ViewModel.CustomerPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15" Padding="12" CornerRadius="8" />
                    </StackPanel>

                    <Button Content="Start Order"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            FontSize="16" FontWeight="SemiBold"
                            Padding="16,16" CornerRadius="10" Margin="0,4,0,0"
                            Command="{x:Bind ViewModel.StartNewOrderCommand}" />
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Page>
