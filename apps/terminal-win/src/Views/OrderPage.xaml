<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TerminalWin.Views.OrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TerminalWin.ViewModels"
    Background="#F1F5F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════ TOP BAR ═══════════════ -->
        <Grid Grid.Row="0" Background="#0F172A" Padding="8,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button Command="{x:Bind ViewModel.GoBackCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="6" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="White" />
                </Button>
                <TextBlock Text="{x:Bind ViewModel.TableLabel, Mode=OneWay}"
                           FontSize="16" FontWeight="SemiBold" Foreground="White"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#1E3A5F" CornerRadius="12" Padding="16,4">
                <TextBlock Text="{x:Bind ViewModel.OrderStatus, Mode=OneWay}"
                           Foreground="#93C5FD" FontSize="12" FontWeight="SemiBold" />
            </Border>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.StaffName, Mode=OneWay}"
                           Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center" />
                <Button Content="Hold" Command="{x:Bind ViewModel.HoldOrderCommand}"
                        Background="Transparent" BorderBrush="#475569" BorderThickness="1"
                        Foreground="#CBD5E1" Padding="12,6" CornerRadius="6" FontSize="12" />
                <Button Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="6">
                    <FontIcon Glyph="&#xE712;" FontSize="16" Foreground="White" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Void Order" />
                            <MenuFlyoutItem Text="Split Bill" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Log Out" Command="{x:Bind ViewModel.LogoutCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- ─────── CATEGORY SIDEBAR ─────── -->
            <Border Grid.Column="0" Background="#F1F5F9"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Categories}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="4" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:CategoryInfo">
                                <Grid Height="48">
                                    <Border Background="{x:Bind BackgroundHex, Mode=OneWay, Converter={StaticResource HexColorToBrushConverter}}"
                                            CornerRadius="8" />
                                    <Rectangle Width="3" HorizontalAlignment="Left"
                                               Fill="White" RadiusX="1.5" RadiusY="1.5" Margin="2,8"
                                               Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Command="{x:Bind SelectCommand}" CommandParameter="{x:Bind Name}"
                                            Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            HorizontalContentAlignment="Left" Padding="20,0"
                                            CornerRadius="8">
                                        <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{x:Bind ForegroundHex, Mode=OneWay, Converter={StaticResource HexColorToBrushConverter}}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Border>

            <!-- ─────── MENU ITEMS GRID ─────── -->
            <ScrollViewer Grid.Column="1" Padding="16" VerticalScrollBarVisibility="Auto"
                          Background="#F8FAFC">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.FilteredMenuItems, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="150" MinItemHeight="100"
                                           MinColumnSpacing="12" MinRowSpacing="12"
                                           ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:MenuItemInfo">
                            <Button Click="MenuItemButton_Click" Tag="{x:Bind}"
                                    Background="White" CornerRadius="12" Padding="16,14"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    IsEnabled="{x:Bind IsAvailable}"
                                    Opacity="{x:Bind ItemOpacity}">
                                <Grid>
                                    <StackPanel Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="14"
                                                   Foreground="#1E293B" TextWrapping="Wrap" />
                                        <Grid>
                                            <TextBlock Text="{x:Bind PriceDisplay}" FontSize="13"
                                                       Foreground="#0369A1" FontWeight="SemiBold" />
                                            <Ellipse Width="8" Height="8" Fill="#22C55E"
                                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </StackPanel>
                                    <Border Visibility="{x:Bind Is86d, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="#DC2626" CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-6,-8,0">
                                        <TextBlock Text="86'd" Foreground="White" FontSize="10" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- ─────── ORDER PANEL ─────── -->
            <Grid Grid.Column="2" Background="White"
                  BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Padding="20,16" Background="#F8FAFC"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <TextBlock Text="Current Order" FontSize="18" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock FontSize="13" Foreground="#64748B" Margin="0,2,0,0">
                        <Run Text="{x:Bind ViewModel.ItemCount, Mode=OneWay}" />
                        <Run Text=" items" />
                    </TextBlock>
                </StackPanel>

                <!-- Order Items -->
                <Grid Grid.Row="1">
                    <!-- Empty state -->
                    <StackPanel Visibility="{x:Bind ViewModel.IsOrderEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE7B8;" FontSize="48" Foreground="#CBD5E1"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No items yet" FontSize="14" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Tap menu items to add" FontSize="12" Foreground="#CBD5E1"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Items list -->
                    <ListView ItemsSource="{x:Bind ViewModel.OrderItems, Mode=OneWay}"
                              SelectionMode="None" Padding="4"
                              Visibility="{x:Bind ViewModel.HasOrderItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="Margin" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:OrderItemDisplay">
                                <StackPanel BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                    <!-- Main row -->
                                    <Grid Padding="12,10" ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Command="{x:Bind DecrementCommand}"
                                                Width="28" Height="28" Padding="0" CornerRadius="6"
                                                Background="#F1F5F9" BorderThickness="0"
                                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                            <TextBlock Text="−" FontSize="14" FontWeight="Bold" Foreground="#64748B" />
                                        </Button>

                                        <TextBlock Grid.Column="1" Text="{x:Bind Quantity, Mode=OneWay}"
                                                   FontSize="14" FontWeight="Bold" Foreground="#0F172A"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <Button Grid.Column="2" Command="{x:Bind IncrementCommand}"
                                                Width="28" Height="28" Padding="0" CornerRadius="6"
                                                Background="#F1F5F9" BorderThickness="0"
                                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                            <TextBlock Text="+" FontSize="14" FontWeight="Bold" Foreground="#64748B" />
                                        </Button>

                                        <Button Grid.Column="3" Command="{x:Bind ToggleExpandedCommand}"
                                                Background="Transparent" BorderThickness="0"
                                                HorizontalContentAlignment="Left" Padding="8,0,0,0"
                                                VerticalAlignment="Center" MinHeight="0" MinWidth="0">
                                            <TextBlock Text="{x:Bind Name}" FontSize="14" Foreground="#1E293B"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Button>

                                        <TextBlock Grid.Column="4" Text="{x:Bind TotalDisplay, Mode=OneWay}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"
                                                   VerticalAlignment="Center" Margin="4,0" />

                                        <Button Grid.Column="5" Command="{x:Bind RemoveCommand}"
                                                Width="28" Height="28" Padding="0" CornerRadius="6"
                                                Background="Transparent" BorderThickness="0">
                                            <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="#94A3B8" />
                                        </Button>
                                    </Grid>

                                    <!-- Expanded: Notes -->
                                    <StackPanel Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Padding="12,0,12,12" Spacing="8" Background="#F8FAFC">
                                        <TextBox PlaceholderText="Add notes..."
                                                 Text="{x:Bind Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" CornerRadius="6" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Footer: Totals + Actions -->
                <StackPanel Grid.Row="2" Padding="20,16" Spacing="10"
                            BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <Grid>
                        <TextBlock Text="Subtotal" FontSize="13" Foreground="#64748B" />
                        <TextBlock Text="{x:Bind ViewModel.SubtotalDisplay, Mode=OneWay}"
                                   FontSize="13" Foreground="#64748B" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Tax (10%)" FontSize="13" Foreground="#64748B" />
                        <TextBlock Text="{x:Bind ViewModel.TaxDisplay, Mode=OneWay}"
                                   FontSize="13" Foreground="#64748B" HorizontalAlignment="Right" />
                    </Grid>
                    <Rectangle Height="1" Fill="#E2E8F0" Margin="0,2" />
                    <Grid>
                        <TextBlock Text="Total" FontSize="20" FontWeight="Bold" Foreground="#0F172A"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.TotalDisplay, Mode=OneWay}"
                                   FontSize="24" FontWeight="Bold" Foreground="#0369A1"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Rectangle Height="1" Fill="#E2E8F0" Margin="0,4" />

                    <Button Content="Send to Kitchen" Command="{x:Bind ViewModel.SendToKitchenCommand}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            FontSize="15" FontWeight="SemiBold"
                            Padding="16,14" CornerRadius="10" />

                    <Button Content="Hold Order" Command="{x:Bind ViewModel.HoldOrderCommand}"
                            HorizontalAlignment="Stretch"
                            FontSize="14" Padding="12,10" CornerRadius="8"
                            Background="Transparent" BorderBrush="#CBD5E1" BorderThickness="1"
                            Foreground="#475569" />

                    <Button Command="{x:Bind ViewModel.GoToPaymentCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="14,12" CornerRadius="10"
                            Background="#16A34A" Foreground="White" BorderThickness="0">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15803D" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#166534" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8C7;" FontSize="14" Foreground="White" />
                            <TextBlock Text="Pay" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
