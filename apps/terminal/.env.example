# Copy to `.env` or `.env.local` in this folder (`apps/terminal`).
# Vite only exposes variables prefixed with `VITE_`.

# Local dev (recommended): relative URL — Vite proxies /api → http://localhost:3000
VITE_API_URL=/api/v1

# Direct URL (Tauri build or when not using the Vite proxy):
# VITE_API_URL=http://localhost:3000/api/v1

# Only this email can submit the sign-in form (must exist in DB / seed).
VITE_SEEDED_ADMIN_EMAIL=owner@universalpos.local

# Must match a Branch id in your database (see `packages/database-schema/prisma/seed.ts`).
VITE_DEFAULT_BRANCH_ID=a0000000-0000-4000-8000-000000000001

# Sent on email login; audit logs use this value.
VITE_DEFAULT_TERMINAL_ID=terminal-dev-001

# Images/receipts upload via API presign → PUT to MinIO (see apps/api/.env S3_*).
# No separate VITE storage URL is required.
