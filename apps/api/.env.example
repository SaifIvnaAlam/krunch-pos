# Server
PORT=3000
CORS_ORIGIN=*

# Database (same as packages/database-schema)
# Port 5433 = Postgres from host tools (psql, Prisma). It is not HTTP — use Adminer for a browser UI:
#   npm run db:up  →  http://localhost:5050  (System: PostgreSQL, Server: postgres, same credentials)
DATABASE_URL=postgresql://postgres:password@localhost:5433/postgres

# JWT (generate strong random hex strings)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=28800

# Redis — omit or set false in production; use true only for local dev without Redis
REDIS_URL=redis://localhost:6379
REDIS_DISABLED=false

# Google Sign-In: OAuth 2.0 Web client ID(s), comma-separated if multiple
GOOGLE_CLIENT_IDS=

# Manager override token TTL (seconds)
OVERRIDE_TOKEN_EXPIRY=60

# Object storage (MinIO on VPS — uses IONOS default-open ports)
# S3 API: http://217.154.53.60  Console: http://217.154.53.60:8443
# If blocked: IONOS → Firewall Policies → allow TCP 80, 8443
S3_ENDPOINT=http://217.154.53.60
S3_REGION=us-east-1
S3_BUCKET=krunch-pos
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRY_SECONDS=900
