# Copy to deploy/.env on the server (or locally before deploy-to-vps.sh).
# Do not commit deploy/.env.

# --- Domains (DNS A records → VPS IP 217.154.53.60) ---
POS_DOMAIN=steakandmarrow.inventivelab.bd
S3_DOMAIN=s3.steakandmarrow.inventivelab.bd
S3_CONSOLE_DOMAIN=s3-console.steakandmarrow.inventivelab.bd
ACME_EMAIL=admin@inventivelab.bd

# --- Postgres ---
POSTGRES_USER=krunch
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=krunch

# --- API (also used by api container) ---
JWT_ACCESS_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=28800
CORS_ORIGIN=https://steakandmarrow.inventivelab.bd
GOOGLE_CLIENT_IDS=
OVERRIDE_TOKEN_EXPIRY=60

# --- MinIO (reuse existing VPS credentials from /root/.env if migrating) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_ENDPOINT=https://s3.steakandmarrow.inventivelab.bd
S3_REGION=us-east-1
S3_BUCKET=krunch-pos
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRY_SECONDS=900

# S3_ACCESS_KEY / S3_SECRET_KEY: set to MINIO_ROOT_USER / MINIO_ROOT_PASSWORD unless you create scoped keys.

# --- n8n (optional: docker compose --profile n8n up) ---
GENERIC_TIMEZONE=Asia/Dhaka
